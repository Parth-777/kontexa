# ---------------------------------------------------------------------------
# Kontexa MCP — browser handoff authentication configuration
# Copy this file to `.env` and adjust values for your environment.
# All values have sensible defaults; everything here is optional.
# (No OAuth, no PKCE — the MCP opens the existing Kontexa /signin page.)
# ---------------------------------------------------------------------------

# Base URL of the Kontexa backend API (issues/refreshes/exchanges tokens).
KONTEXA_BASE_URL=http://localhost:5000

# Base URL where the Kontexa web app (login page) is served.
KONTEXA_FRONTEND_URL=http://localhost:3000

# Override individual endpoints only if they differ from the defaults
# derived from the URLs above.
# KONTEXA_LOGIN_PAGE_URL=http://localhost:3000/signin
# KONTEXA_EXCHANGE_ENDPOINT=http://localhost:5000/api/auth/mcp/exchange
# KONTEXA_REFRESH_ENDPOINT=http://localhost:5000/api/auth/refresh
# KONTEXA_LOGOUT_ENDPOINT=http://localhost:5000/api/auth/logout

# The Kontexa "ask a question" endpoint the ask_kontexa tool forwards to.
# KONTEXA_QUESTION_ENDPOINT=http://localhost:5000/api/decision/v1/run

# Optional tenant/workspace override sent as X-Client-Id. When unset, the
# tenant is taken from the logged-in session's workspace context.
# KONTEXA_TENANT_ID=

# Loopback redirect settings for the browser handoff.
# Port 0 means "pick a random free port" (recommended).
KONTEXA_REDIRECT_HOST=127.0.0.1
KONTEXA_REDIRECT_PORT=0
KONTEXA_REDIRECT_PATH=/callback

# How long (ms) to wait for the user to finish logging in before timing out.
KONTEXA_LOGIN_TIMEOUT_MS=300000

# Treat the access token as expired this many ms before its real expiry.
KONTEXA_TOKEN_EXPIRY_SKEW_MS=30000

# Absolute path for the encrypted local session file.
# Defaults to <home>/.kontexa/session.json
# KONTEXA_SESSION_FILE=

# Log verbosity: debug | info | warn | error | silent
KONTEXA_LOG_LEVEL=info
