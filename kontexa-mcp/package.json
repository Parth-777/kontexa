{
  "name": "kontexa-mcp",
  "version": "0.0.1",
  "private": true,
  "description": "Kontexa MCP server — Phase 0 authentication foundation. Browser-based OAuth login, secure local session storage, and token refresh. No Claude tools or analytics logic yet.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kontexa-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js serve",
    "serve": "node dist/index.js serve",
    "smoke": "node dist/index.js ask \"Which companies generate the highest revenue?\"",
    "auth:login": "node dist/index.js login",
    "auth:logout": "node dist/index.js logout",
    "auth:status": "node dist/index.js status",
    "auth:refresh": "node dist/index.js refresh"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
